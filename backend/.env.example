# Настройки окружения — скопируй в .env и заполни значения

# Сервер
PORT=3000
NODE_ENV=production

# База данных PostgreSQL
DATABASE_URL=postgresql://nahockey_user:STRONG_PASSWORD@localhost:5432/nahockey_db

# JWT
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# CORS — домен фронтенда (без слеша в конце)
ALLOWED_ORIGIN=https://nahockey.ru
