# Настройки окружения — скопируй в .env и заполни значения

# Сервер
PORT=3000
NODE_ENV=production
APP_URL=https://nahockey.ru

# База данных PostgreSQL
DATABASE_URL=postgresql://nahockey_user:STRONG_PASSWORD@localhost:5432/nahockey_db

# JWT
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=30d

# CORS — домен фронтенда (без слеша в конце)
ALLOWED_ORIGIN=https://nahockey.ru

# ===== SMS (SMSC.ru) =====
# Зарегистрируйся на smsc.ru и вставь логин/пароль
SMSC_LOGIN=your_smsc_login
SMSC_PASSWORD=your_smsc_password
# Для разработки: SMS_TEST=1 — SMS не отправляются, код пишется в лог
SMS_TEST=0

# ===== ЮКасса (YooKassa) =====
# shopId и secretKey из личного кабинета yookassa.ru
# В тест-режиме (без ключей) платежи эмулируются, реальных списаний нет
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# ===== Firebase Admin (Push-уведомления) =====
# Скачай serviceAccountKey.json из Firebase Console → Project Settings → Service accounts
# Укажи ПОЛНЫЙ путь до файла
FIREBASE_CREDENTIALS=/opt/nahockey/firebase-service-account.json
